# Econstruct Inc — .gitignore

# Environment variables — NEVER commit tokens
.env
.env.*
*.env

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Python
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
*.egg-info/

# Node
node_modules/
npm-debug.log*

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Build output
dist/
build/
.cache/
