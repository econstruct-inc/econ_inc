---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
---

<BaseLayout
  title="Construction videos | econstruct Los Angeles"
  description="Watch econstruct construction videos for Los Angeles retail, restaurant, office TI, residential, and ADU project work."
  path="/videos/"
>
  <section class="service-hero">
    <div class="container section-heading">
      <span class="eyebrow">Videos</span>
      <h1>Construction video library.</h1>
      <p class="lead">Video content helps clients evaluate workmanship, project fit, and the kinds of spaces econstruct can build in Los Angeles.</p>
    </div>
  </section>

  <section class="section dark">
    <div class="container image-banner-content">
      <span class="eyebrow">Featured video</span>
      <h2>See how econstruct approaches commercial and residential construction.</h2>
      <p>Production embeds can be added here after the final YouTube list is approved. For launch, this page preserves the indexed WordPress video destination and gives search engines a clean topical hub.</p>
      <a class="button" href="/contact/">Ask for relevant project examples</a>
    </div>
  </section>

  <CTA />
</BaseLayout>
