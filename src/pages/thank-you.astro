---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank you | econstruct"
  description="Thank you for contacting econstruct."
  path="/thank-you/"
>
  <section class="service-hero">
    <div class="container section-heading">
      <span class="eyebrow">Message sent</span>
      <h1>Thank you.</h1>
      <p>Your message has been sent to econstruct. The team will follow up directly.</p>
      <div class="button-row">
        <a class="button" href="/">Return home</a>
        <a class="button secondary" href="/projects/">View projects</a>
      </div>
    </div>
  </section>
</BaseLayout>
