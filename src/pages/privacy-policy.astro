---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy policy | econstruct"
  description="Privacy policy for the econstruct website and contact form."
  path="/privacy-policy/"
>
  <section class="section white">
    <div class="container section-heading">
      <span class="eyebrow">Privacy Policy</span>
      <h1>Privacy policy.</h1>
      <p>econstruct uses website contact information only to respond to project inquiries and business requests.</p>
    </div>
    <div class="container">
      <h2>Information collected</h2>
      <p>The contact form may collect your name, email address, phone number, project type, and message. Technical information may also be processed by Cloudflare for security, spam prevention, and site delivery.</p>
      <h2>How information is used</h2>
      <p>Submitted information is emailed to econstruct and used to respond to your inquiry. The website does not sell personal information.</p>
      <h2>Contact</h2>
      <p>Questions about this policy can be sent to frank@econstructinc.com.</p>
    </div>
  </section>
</BaseLayout>
