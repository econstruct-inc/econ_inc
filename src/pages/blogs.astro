---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout
  title="Los Angeles construction blog | econstruct"
  description="Read econstruct construction insights for Los Angeles commercial TI, ADU construction, bar construction, fire rebuilds, and residential projects."
  path="/blogs/"
>
  <section class="service-hero">
    <div class="container section-heading">
      <span class="eyebrow">Blogs</span>
      <h1>Construction insights for Los Angeles owners.</h1>
      <p class="lead">Blog content should answer real buyer questions and send qualified visitors toward the right service page or contact form.</p>
    </div>
  </section>

  <section class="section cream">
    <div class="container grid three">
      {posts.map((post) => (
        <article class="blog-card">
          <img src={post.data.image} alt={post.data.imageAlt} loading="lazy" />
          <div class="blog-card-body">
            <div class="meta"><span>{post.data.category}</span><span>{post.data.publishDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span></div>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <a class="button ghost" href={`/blogs/${post.id}/`}>Read {post.data.category}</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <CTA />
</BaseLayout>
