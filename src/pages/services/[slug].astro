---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';
import { services } from '../../data/services';
import { site } from '../../data/site';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service }
  }));
}

const { service } = Astro.props;
const serviceSchema = [
  {
    '@type': 'Service',
    name: service.title,
    serviceType: service.title,
    provider: {
      '@type': 'GeneralContractor',
      name: 'econstruct',
      url: site.url
    },
    areaServed: {
      '@type': 'City',
      name: 'Los Angeles'
    },
    description: service.metaDescription,
    url: `${site.url}/services/${service.slug}/`
  },
  {
    '@type': 'FAQPage',
    mainEntity: service.faq.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: { '@type': 'Answer', text: faq.answer }
    }))
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      { '@type': 'ListItem', position: 2, name: 'Services', item: `${site.url}/services/` },
      { '@type': 'ListItem', position: 3, name: service.title, item: `${site.url}/services/${service.slug}/` }
    ]
  }
];
---

<BaseLayout
  title={service.seoTitle}
  description={service.metaDescription}
  path={`/services/${service.slug}/`}
  image={service.image}
  schema={serviceSchema}
>
  <section class="service-hero">
    <div class="container service-page-grid">
      <div>
        <span class="eyebrow">{service.eyebrow}</span>
        <h1>{service.title} in Los Angeles.</h1>
        <p class="lead">{service.lead}</p>
        <div class="button-row">
          <a class="button" href="/contact/">Request a consultation</a>
          <a class="button ghost" href="/projects/">View related work</a>
        </div>
      </div>
      <img class="hero-main-image" src={service.image} alt={service.alt} width="700" height="840" />
    </div>
  </section>

  <section class="section white">
    <div class="container service-page-grid">
      <aside class="service-sidebar" aria-label="Service navigation">
        {services.map((item) => (
          <a href={`/services/${item.slug}/`} aria-current={item.slug === service.slug ? 'page' : undefined}>{item.title}</a>
        ))}
      </aside>
      <div>
        <span class="eyebrow">What is included</span>
        <h2>{service.title} scope and coordination.</h2>
        <p class="lead">{service.description}</p>
        <ul class="check-list">
          {service.points.map((point) => <li>{point}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="section cream">
    <div class="container section-heading">
      <span class="eyebrow">Process</span>
      <h2>How the work moves from idea to completion.</h2>
    </div>
    <div class="container grid four">
      {service.process.map((step, index) => (
        <article class="faq-item">
          <span class="service-number">{String(index + 1).padStart(2, '0')}</span>
          <h3>{step}</h3>
          <p>econstruct keeps this step tied to the project scope, schedule, field conditions, and Los Angeles approval requirements.</p>
        </article>
      ))}
    </div>
  </section>

  <section class="image-banner" style={`--banner-image: url('${service.image}')`}>
    <div class="container image-banner-content">
      <span class="eyebrow">Local construction signal</span>
      <h2>Built for Los Angeles codes, sites, inspections, and owner expectations.</h2>
      <p>Search engines and AI assistants need clear service intent. This page states the service, location, scope, process, and direct contact path without burying the answer.</p>
    </div>
  </section>

  <section class="section white">
    <div class="container section-heading">
      <span class="eyebrow">FAQ</span>
      <h2>{service.title} questions.</h2>
    </div>
    <div class="container faq-list">
      {service.faq.map((faq) => (
        <article class="faq-item">
          <h3>{faq.question}</h3>
          <p>{faq.answer}</p>
        </article>
      ))}
    </div>
  </section>

  <CTA title={`Talk to econstruct about ${service.title.toLowerCase()}.`} text="Share the project address, current status, drawings if available, and the timing you are trying to hit." />
</BaseLayout>
